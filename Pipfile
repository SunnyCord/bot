[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
"discord.py" = {version = ">=2.7.1", extras = ["speed", "voice"]}
"motor" = {version = ">=3.1.1"}
jishaku = ">=2.5.1"
sentry-sdk = ">=1.11.0"
pytimeparse = ">=1.1.8"
dataclasses-json = ">=0.5.7"
aiosu = "*"
orjson = "*"
cryptography = "*"
redis = {extras = ["hiredis"], version = "*"}
matplotlib = "*"
aiordr = "*"
pomice = "*"
thefuzz = {extras = ["speedup"], version = "*"}
pydantic = "*"
pydantic-core = "*"
async-timeout = "*"
numpy = "*"

[dev-packages]
black = ">=22.10.0"
pre-commit = "*"

[requires]
python_version = "3.11"

[scripts]
start = "bash -c 'cd src && python run.py'"
